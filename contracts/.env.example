# ─── Deployer Key ────────────────────────────────────────────────────────────
# The private key of the wallet that will deploy the contracts.
# NEVER commit the real .env file — this is just the template.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── RPC Endpoint ────────────────────────────────────────────────────────────
# Sepolia RPC with fhEVM support. Use Zama's node or Infura/Alchemy + Zama plugin.
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ─── Chainlink Price Feed (Sepolia) ──────────────────────────────────────────
# ETH/USD feed on Sepolia (used by NullOracle)
CHAINLINK_ETH_USD_FEED=0x694AA1769357215DE4FAC081bf1f309aDC325306
